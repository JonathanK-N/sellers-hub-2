# ---- Backend AfriMarket — variables d'environnement ----

# Base de données MongoDB (Railway fournit cette URL via le service MongoDB)
# Sur Railway, référence la variable du service Mongo : ${{ MongoDB.MONGO_URL }}
MONGO_URL=mongodb://localhost:27017
DB_NAME=afrimarket

# Sécurité — génère une longue chaîne aléatoire (ex: openssl rand -hex 32)
JWT_SECRET=change-me-with-a-long-random-secret

# CORS — domaine(s) du frontend autorisé(s), séparés par des virgules
# Mets l'URL publique de ton service frontend Railway
CORS_ORIGINS=https://ton-frontend.up.railway.app

# Mode de paiement : sandbox (test) ou production
PAYMENT_MODE=sandbox

# ---- CinetPay (agrégateur Mobile Money) — à remplir pour la production ----
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_NOTIFY_URL=https://ton-backend.up.railway.app/api/payments/webhook/cinetpay
CINETPAY_RETURN_URL=https://ton-frontend.up.railway.app/buyer/orders
CINETPAY_TRANSFER_TOKEN=

# ---- Firebase Cloud Messaging (push) — optionnel ----
FIREBASE_PROJECT_ID=
FIREBASE_SA_JSON=

# ---- Stockage objet (photos produits / docs KYC) ----
EMERGENT_LLM_KEY=
APP_NAME=afrimarket
