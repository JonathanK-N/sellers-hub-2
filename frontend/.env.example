# ---- Frontend AfriMarket — variables d'environnement ----
# IMPORTANT : ces variables sont injectées AU MOMENT DU BUILD (React les inline
# dans le bundle). Elles doivent donc être définies dans Railway AVANT le build.

# URL publique du backend (service backend Railway), SANS slash final
REACT_APP_BACKEND_URL=https://ton-backend.up.railway.app

# ---- Firebase (push notifications) — optionnel ----
# Config Firebase au format JSON (une seule ligne)
REACT_APP_FIREBASE_CONFIG=
REACT_APP_FCM_VAPID_KEY=
